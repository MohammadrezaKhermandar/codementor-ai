# =============================================
# CodeMentor AI — Environment Variables
# =============================================
# Copy this file to .env.local and fill in your values.

# Required: Google Gemini API Key
# Get it from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_google_gemini_api_key_here

# Optional but recommended: GitHub Personal Access Token
# Needed for GitHub Review Tool to fetch private repos & avoid rate limits
# Create at: https://github.com/settings/tokens (needs repo:read scope)
GITHUB_TOKEN=your_github_token_here
